# project related
DOXYFILE_ENCODING  = UTF-8
PROJECT_NAME        = "Chess Engine"
PROJECT_NUMBER      = 0.0.1
PROJECT_BRIEF       = "A high-performance bitboard chess engine in C++"
OUTPUT_DIRECTORY    = build/docs
CREATE_SUBDIRS = YES
ALLOW_UNICODE_NAMES = YES

# build related
EXTRACT_ALL = YES
EXTRACT_PRIVATE = YES
EXTRACT_STATIC = YES
SHOW_INCLUDE_FILES = YES
INLINE_SOURCES = YES
SOURCE_BROWSER = YES
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION = YES

# warning and log
QUIET = YES
WARNINGS = YES
WARN_IF_UNDOCUMENTED = YES
WARN_IF_DOC_ERROR = YES
WARN_NO_PARAMDOC = YES

# input and parsing
INPUT = src README.md
INPUT_ENCODING = UTF-8
RECURSIVE           = YES
USE_MDFILE_AS_MAINPAGE = README.md
EXCLUDE = src/test

# html output
GENERATE_HTML = YES
HTML_OUTPUT = html
HTML_FILE_EXTENSION = .html
GENERATE_TREEVIEW = YES
DISABLE_INDEX = NO
FULL_SIDEBAR = YES
HTML_COLORSTYLE = DARK
# who uses light mode?

GENERATE_LATEX = NO

# graphviz
HAVE_DOT = YES
DOT_NUM_THREADS = 0
DOT_IMAGE_FORMAT = svg
INTERACTIVE_SVG = YES
CLASS_GRAPH = YES
COLLABORATION_GRAPH = YES
INCLUDE_GRAPH = YES
INCLUDED_BY_GRAPH = YES
CALL_GRAPH = YES
CALLER_GRAPH = YES

# very important! haha
NUM_PROC_THREADS = 0